src/**
tsconfig.json
eslint.config.mjs
.prettierrc
.gitignore
**/*.ts
**/*.map

# native binaries not needed (pdfjs webview-only)
node_modules/@napi-rs/**

# pdfjs — only need build/{pdf.min.mjs,pdf.worker.min.mjs}
node_modules/pdfjs-dist/legacy/**
node_modules/pdfjs-dist/types/**
node_modules/pdfjs-dist/lib/**
node_modules/pdfjs-dist/build/pdf.sandbox*
node_modules/pdfjs-dist/build/*.js

# highlight.js — keep core + common languages only via .hljs auto-detect
node_modules/highlight.js/scss/**
node_modules/highlight.js/types/**
node_modules/highlight.js/es/**

# jsdom — trim tests, docs
node_modules/jsdom/lib/jsdom/browser/resources/**

# resvg-wasm — trim extras (keep index.js + wasm binary)
node_modules/@resvg/resvg-wasm/README.md
